# ── Server-side (Vercel environment variables — NEVER prefix with VITE_) ─────
# Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Supabase service role key (for api/share.ts and api/discover.ts)
# Find it at: Supabase dashboard → Settings → API → service_role secret
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Client-side (safe to expose — Vite bundles these into the browser) ───────
# Supabase anon key (public, read-only access)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
